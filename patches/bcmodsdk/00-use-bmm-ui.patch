+	// on clean return. If onExit is never called (crash), the frame stays on the stack
+	// and window.onerror can attribute the error to the right mod.
+	api.errorReporterHooks.hookEnter = (fn: string, mod: string): (() => void) => {
+		const frame: _CrashFrame = { type: 'hook', fn, mod };
+		contextStack.push(frame);
+		return () => {
